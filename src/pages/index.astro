---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/base';
import { getSitePosts } from '../lib/posts';

const posts = await getSitePosts();
const games = await getCollection('games');
const latest = [
  ...posts.map((post) => ({
    title: post.title,
    date: post.date,
    kind: post.section,
    href: withBase(`${post.section === '摘录' ? '/excerpts' : '/writing'}/${post.path}`)
  })),
  ...games
    .filter((game) => game.data.date instanceof Date)
    .map((game) => ({
      title: game.data.title,
      date: game.data.date as Date,
      kind: 'Game',
      href: game.data.href
    }))
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">

  <p>
    这是一些最新的内容：
    {
      latest.map((item, index) => (
        <>
          <a href={item.href}>{item.title}</a>
          {index < latest.length - 1 ? '，' : ''}
        </>
      ))
    }
  </p>
</BaseLayout>
