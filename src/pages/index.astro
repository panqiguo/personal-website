---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/base';
import { getSitePosts } from '../lib/posts';

const posts = await getSitePosts();
const games = await getCollection('games');
const latest = [
  ...posts.map((post) => ({
    title: post.title,
    date: post.date,
    kind: 'Writing',
    href: withBase(`/writing/${post.slug}`)
  })),
  ...games
    .filter((game) => game.data.date instanceof Date)
    .map((game) => ({
      title: game.data.title,
      date: game.data.date as Date,
      kind: 'Game',
      href: game.data.href
    }))
]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 2);
---

<BaseLayout title="Home">
  <section class="intro-block">
    <p>
      我在这里写一些长期有价值的笔记，也会记录自己做过、玩过、推荐过的游戏。
      这个网站希望像一本纸质册子: 简单、安静、可长期维护。
    </p>
  </section>

  <section class="section-block">
    <div class="section-head">
      <h2>Latest</h2>
    </div>
    <ul class="text-list">
      {
        latest.map((item) => (
          <li>
            <a href={item.href} class="latest-link">
              {item.title}
            </a>
            <span class="muted">{item.kind}</span>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
