---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/base';
import { getPostsBySection } from '../../lib/posts';

const posts = await getPostsBySection('散文');
---

<BaseLayout title="散文">

    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <div class="post-line">
              <a href={withBase(`/writing/${post.path}`)} class="post-title">
              {post.title}
              </a>
              {post.featured && (
                <div class="post-meta-row">
                  <strong>Featured</strong>
                </div>
              )}
            </div>
            {post.summary && <p>{post.summary}</p>}
          </li>
        ))
      }
    </ul>

</BaseLayout>
