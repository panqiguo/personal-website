---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/base';
import { getSitePosts } from '../../lib/posts';

const posts = await getSitePosts();
---

<BaseLayout title="Writing">

    <h2>Writing</h2>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <div class="post-line">
              <a href={withBase(`/writing/${post.slug}`)} class="post-title">
                {post.title}
              </a>
              <div class="post-meta-row">
                <time datetime={post.date.toISOString()}>
                  {post.date.toLocaleDateString('en-CA')}
                </time>
                {post.featured && <strong>Featured</strong>}
              </div>
            </div>
            {post.summary && <p>{post.summary}</p>}
          </li>
        ))
      }
    </ul>

</BaseLayout>
