---
import '../styles/global.css';
import { stripBase, withBase } from '../lib/base';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = stripBase(Astro.url.pathname);
const baseUrl = import.meta.env.BASE_URL || '/';

const nav = [
  { href: '/', match: '/', label: 'Home' },
  { href: 'writing', match: '/writing', label: 'Writing' },
  { href: 'games', match: '/games', label: 'Games' }
];

const isActive = (match: string) =>
  match === '/' ? pathname === '/' : pathname.startsWith(match);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-title" href={withBase('/')}>papergrid</a>
        <nav aria-label="Primary" class="top-nav">
          {
            nav.map((item) => (
              <a
                href={withBase(item.href)}
                class:list={{ active: isActive(item.match) }}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>

    <script is:inline define:vars={{ baseUrl }}>
      const normalizeBase = (base) => {
        if (!base) return '/';
        return base.endsWith('/') ? base : `${base}/`;
      };

      const siteBase = normalizeBase(baseUrl);
      const origin = window.location.origin;

      const addBase = (urlPath) => {
        if (!urlPath.startsWith('/')) return urlPath;
        if (urlPath.startsWith('//')) return urlPath;
        if (siteBase !== '/' && urlPath.startsWith(siteBase)) return urlPath;
        const tail = urlPath.replace(/^\/+/, '');
        return `${siteBase}${tail}`;
      };

      document.querySelectorAll('a[href^="/"]').forEach((a) => {
        const href = a.getAttribute('href');
        if (!href || href.startsWith('//')) return;
        a.setAttribute('href', addBase(href));
      });

      document.querySelectorAll('img[src^="/"]').forEach((img) => {
        const src = img.getAttribute('src');
        if (!src || src.startsWith('//')) return;
        img.setAttribute('src', addBase(src));
      });

      document.querySelectorAll('a[href]').forEach((a) => {
        const href = a.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
          return;
        }

        try {
          const url = new URL(href, window.location.href);
          if (url.origin !== origin) {
            a.classList.add('external-link');
            if (!a.hasAttribute('target')) a.setAttribute('target', '_blank');
            a.setAttribute('rel', 'noopener noreferrer');
          }
        } catch {
          // Ignore invalid URLs.
        }
      });
    </script>
  </body>
</html>
